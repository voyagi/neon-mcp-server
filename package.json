{
	"name": "upwork-mcp-server",
	"version": "0.1.0",
	"private": true,
	"description": "MCP server connecting Supabase database to Claude — Upwork portfolio demo",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"check": "biome check --write .",
		"lint": "biome lint --write .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.1",
		"@supabase/supabase-js": "^2.49.4",
		"zod": "^4.3.6"
	},
	"knip": {
		"ignore": [
			".claude/**"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/node": "^22.15.0",
		"@vitest/coverage-v8": "^4.0.18",
		"tsx": "^4.19.4",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	}
}
